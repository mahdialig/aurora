# Copy to .env and fill in. Never commit .env.

# --- LLM (DeepSeek) ---
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Telegram surface ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your numeric Telegram user id. Only this user may talk to the bot.
# Send /start to the bot (or @userinfobot) to discover your id, then set it here.
AURORA_ALLOWED_USER_ID=

# --- Behavior ---
# Starting autonomy preset: approve_all | digest | auto_low_risk | autonomous
AURORA_AUTONOMY_MODE=approve_all
