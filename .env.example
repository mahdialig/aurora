# Copy to .env and fill in. Never commit .env.

# --- LLM (DeepSeek) ---
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Telegram surface ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your numeric Telegram user id. Only this user may talk to the bot.
# Send /start to the bot (or @userinfobot) to discover your id, then set it here.
AURORA_ALLOWED_USER_ID=

# --- Work email (IMAP/SMTP, e.g. dapurhosting cPanel) ---
# Leave WORK_EMAIL/WORK_PASSWORD blank to skip the work account.
# Host/ports default to dapurhosting cPanel (IMAP 993 SSL, SMTP 465 SSL).
WORK_EMAIL=
WORK_PASSWORD=
WORK_IMAP_HOST=d001.dapurhosting.com
WORK_IMAP_PORT=993
WORK_SMTP_HOST=d001.dapurhosting.com
WORK_SMTP_PORT=465

# --- Behavior ---
# Starting autonomy preset: approve_all | digest | auto_low_risk | autonomous
AURORA_AUTONOMY_MODE=approve_all

# --- Proactive notifications ---
# Aurora checks for new mail on a timer and pings you about what matters.
AURORA_NOTIFY_ENABLED=true
AURORA_NOTIFY_INTERVAL_SECONDS=600

# --- Don't-miss-a-thing engine (M4): daily brief + weekly review ---
# Local timezone for scheduled briefs (IANA name).
AURORA_TIMEZONE=Asia/Jakarta
# Daily morning brief: a short, structured rundown of what needs you today.
AURORA_BRIEF_ENABLED=true
AURORA_BRIEF_TIME=07:00
AURORA_BRIEF_HORIZON_DAYS=7
# Weekly review: looks ~two weeks ahead. Day is 0=Mon .. 6=Sun.
AURORA_WEEKLY_REVIEW_ENABLED=true
AURORA_WEEKLY_REVIEW_DAY=0
AURORA_WEEKLY_REVIEW_TIME=07:30
AURORA_WEEKLY_HORIZON_DAYS=14
